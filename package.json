{
  "name": "@tippingchain/sdk",
  "version": "2.0.3",
  "type": "module",
  "description": "TippingChain SDK v2.0 - Multi-chain tipping with USDC payouts on ApeChain",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "TippingChain Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tippingchain/tippingchain.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/tippingchain/tippingchain#readme",
  "bugs": {
    "url": "https://github.com/tippingchain/tippingchain/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "node_modules/.bin/tsup",
    "dev": "node_modules/.bin/tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepublishOnly": "npm run clean && npm run build",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "apechain",
    "tipping",
    "crypto",
    "multi-chain",
    "web3",
    "ethereum",
    "polygon",
    "optimism",
    "bsc",
    "cross-chain",
    "defi"
  ],
  "peerDependencies": {
    "thirdweb": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "thirdweb": {
      "optional": true
    }
  },
  "dependencies": {
    "@tippingchain/contracts-interface": "^1.2.0",
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "rimraf": "^5.0.0",
    "thirdweb": "^5.105.26",
    "ts-jest": "^29.0.0",
    "tsup": "^8.5.0"
  }
}
